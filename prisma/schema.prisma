generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Maps to existing 'users' table
model User {
  id                     Int       @id @default(autoincrement())
  email                  String    @unique
  name                   String
  password               String?
  role                   String    @default("user")
  subscriptionStatus     String    @default("inactive") @map("subscriptionStatus")
  last_login_at          DateTime? @map("last_login_at")
  discord_access_token   String?   @map("discord_access_token")
  discord_refresh_token  String?   @map("discord_refresh_token")
  google_access_token    String?   @map("google_access_token")
  google_refresh_token   String?   @map("google_refresh_token")
  google_scopes          String?   @map("google_scopes")
  registeredAt           DateTime  @default(now()) @map("registeredAt")
  is_verified            Boolean   @default(false) @map("is_verified")
  verification_code      String?   @map("verification_code")
  auditTrail             Json?
  activities             ActivityLog[]
  watchlist              Watchlist[]
  accounts               Account[]
  sessions               Session[]
  resetTokens            ResetToken[]
  @@map("users")
}

// Maps to existing 'products' table
model Product {
  product_id   Int      @id @default(autoincrement()) @map("product_id")
  retailer     String
  title        String
  url          String
  image        String?
  screenshot   String?
  stock_status String   @map("stock_status")
  release_date DateTime? @map("release_date")
  priceHistory PriceHistory[]
  @@map("products")
}

// Maps to existing 'pricehistory' table
model PriceHistory {
  id          Int      @id @default(autoincrement())
  product_id  Int      @map("product_id")
  retailer    String
  price       Decimal  @db.Decimal(10, 2)
  recorded_at DateTime @default(now()) @map("recorded_at")
  product     Product  @relation(fields: [product_id], references: [product_id], onDelete: Cascade)
  @@index([product_id], map: "PriceHistory_productId_fkey")
  @@map("pricehistory")
}

// Maps to existing 'watchlist' table
model Watchlist {
  id              Int      @id @default(autoincrement())
  retailer_name   String   @map("retailer_name")
  product_url     String?  @map("product_url")
  product_title   String   @map("product_title")
  price           Decimal  @db.Decimal(10, 2)
  stock_quantity  Int?     @map("stock_quantity")
  stock_status    String?  @map("stock_status")
  user_id         Int      @map("user_id")
  user            User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  @@index([user_id])
  @@map("watchlist")
}

// Maps to existing 'waitlist' table
model Waitlist {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  name       String
  created_at DateTime @default(now()) @map("created_at")
  status     String   @default("PENDING")
  source     String   @default("WEBSITE")
  metadata   Json?
  @@map("waitlist")
}

// Maps to existing 'activitylog' table
model ActivityLog {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("userId")
  action    String
  timestamp DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@map("activitylog")
}

// Maps to existing 'resettoken' table
model ResetToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  createdAt DateTime @default(now())
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

// Maps to existing 'account' table
model Account {
  id                String  @id @default(cuid())
  userId            Int
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
  @@index([userId])
}

// Maps to existing 'session' table
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       Int
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

// Maps to existing 'verificationtoken' table
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}
// Maps to existing 'reset_tokens' table (note the table name)
model ResetToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  createdAt DateTime @default(now())
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@map("reset_tokens")
}

// Maps to existing 'account' table
model Account {
  id                String  @id @default(cuid())
  userId            Int
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
  @@index([userId])
}

// Maps to existing 'session' table
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       Int
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

// Maps to existing 'verificationtoken' table
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

// ===== NEW CARD TRADING MODELS =====

// Card master data - the actual Pokemon cards
model Card {
  id              Int      @id @default(autoincrement())
  name            String   @db.VarChar(255)
  set_name        String   @map("set_name") @db.VarChar(255)
  set_number      String   @map("set_number") @db.VarChar(100)
  rarity          String   @db.VarChar(100)
  card_type       String   @map("card_type") @db.VarChar(100) // e.g., "Pokemon", "Trainer", "Energy"
  subtype         String?  @db.VarChar(100) // e.g., "Basic", "Stage 1", "GX"
  hp              Int?     // Health points for Pokemon cards
  image_url       String?  @map("image_url") @db.Text
  small_image_url String?  @map("small_image_url") @db.Text
  tcg_id          String?  @unique @map("tcg_id") @db.VarChar(255) // External API ID if using Pokemon TCG API
  created_at      DateTime @default(now()) @map("created_at")
  updated_at      DateTime @updatedAt @map("updated_at")
  
  // Relations
  userCards       UserCard[]
  
  @@index([name])
  @@index([set_name])
  @@map("cards")
}

// User's card collection - individual card instances owned by users
model UserCard {
  id              Int       @id @default(autoincrement())
  card_id         Int       @map("card_id")
  owner_id        Int       @map("owner_id")
  condition       String    @default("NM") // NM, LP, MP, HP, DMG (for future use)
  is_for_sale     Boolean   @default(false) @map("is_for_sale")
  sale_type       String?   @map("sale_type") // "FIXED" or "AUCTION"
  fixed_price     Decimal?  @db.Decimal(10, 2) @map("fixed_price")
  reserve_price   Decimal?  @db.Decimal(10, 2) @map("reserve_price") // Minimum auction price
  auction_end     DateTime? @map("auction_end")
  is_sold         Boolean   @default(false) @map("is_sold")
  notes           String?   @db.Text // User notes about the card
  acquired_date   DateTime  @default(now()) @map("acquired_date")
  created_at      DateTime  @default(now()) @map("created_at")
  updated_at      DateTime  @updatedAt @map("updated_at")
  
  // Relations
  card            Card      @relation(fields: [card_id], references: [id], onDelete: Cascade)
  owner           User      @relation(fields: [owner_id], references: [id], onDelete: Cascade)
  bids            Bid[]
  cardHistory     CardHistory[]
  
  @@index([owner_id])
  @@index([card_id])
  @@index([is_for_sale])
  @@index([sale_type])
  @@map("user_cards")
}

// Bidding system for auction cards
model Bid {
  id            Int      @id @default(autoincrement())
  user_card_id  Int      @map("user_card_id")
  bidder_id     Int      @map("bidder_id")
  amount        Decimal  @db.Decimal(10, 2)
  is_active     Boolean  @default(true) @map("is_active")
  created_at    DateTime @default(now()) @map("created_at")
  
  // Relations
  userCard      UserCard @relation(fields: [user_card_id], references: [id], onDelete: Cascade)
  bidder        User     @relation(fields: [bidder_id], references: [id], onDelete: Cascade)
  
  @@index([user_card_id])
  @@index([bidder_id])
  @@index([created_at])
  @@index([is_active])
  @@map("bids")
}


generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                    Int                    @id @default(autoincrement())
  email                 String                 @unique(map: "email") @db.VarChar(255)
  name                  String                 @db.VarChar(255)
  password              String                 @db.VarChar(255)
  role                  String                 @default("user") @db.VarChar(50)
  subscriptionStatus    String                 @default("inactive") @map("subscriptionStatus") @db.VarChar(50)
  last_login_at         DateTime?              @map("last_login_at") @db.DateTime(0)
  discord_access_token  String?                @map("discord_access_token") @db.VarChar(255)
  discord_refresh_token String?                @map("discord_refresh_token") @db.VarChar(255)
  google_access_token   String?                @map("google_access_token") @db.VarChar(255)
  google_refresh_token  String?                @map("google_refresh_token") @db.VarChar(255)
  google_scopes         String?                @map("google_scopes") @db.VarChar(255)
  registeredAt          DateTime               @default(now()) @map("registeredAt") @db.DateTime(0)
  is_verified           Int?                   @default(0) @map("is_verified") @db.TinyInt
  verification_code     String?                @map("verification_code") @db.VarChar(10)
  
  // Relations
  watchlistItems        Watchlist[]            @relation("UserWatchlist")
  userCards             UserCard[]             @relation("UserToUserCard")
  activityLogs          ActivityLog[]          @relation("UserActivity")
  bids                  Bid[]                  @relation("BidToUser")
  historyFrom           CardTransactionHistory[] @relation("HistoryFromUser")
  historyTo             CardTransactionHistory[] @relation("HistoryToUser")
  wallet                UserWallet?            @relation
  walletTransactions    WalletTransaction[]    @relation("UserWalletTransaction")
  notifications         Notification[]         @relation("UserNotifications")
  
  @@map("users")
}

// NEW: Pokemon Set table
model PokemonSet {
  id              String    @id                 // "base1", "jungle", etc. from API
  name            String    @unique             // "Base Set", "Jungle", etc.
  series          String                        // "Base", "Neo", "E-Card", etc.
  printed_total   Int?                          // Number on cards (e.g., "102")
  total           Int?                          // Actual total including secret rares
  legalities      Json?                         // {"standard": "Legal", "expanded": "Legal"}
  ptcgo_code      String?                       // "BAS", "JUN" - PTCGO code
  release_date    String                        // "1999/01/09"
  images          Json?                         // {"symbol": "url", "logo": "url"}
  api_updated_at  DateTime?                     // Last API sync
  created_at      DateTime  @default(now()) @db.DateTime(0)
  updated_at      DateTime  @updatedAt @db.DateTime(0)
  
  // Relations
  cards           Card[]    @relation("SetCards")
  
  @@index([series])
  @@index([release_date])
  @@map("pokemon_sets")
}

// NEW: Rarity table
model Rarity {
  id          Int      @id @default(autoincrement())
  name        String   @unique                 // "Common", "Uncommon", "Rare", "Holo Rare"
  symbol      String?  @db.VarChar(20)         // "●", "◆", "★", "☆"
  order_index Int?     @default(0)             // For sorting (Common=1, Rare=5, etc.)
  color       String?  @db.VarChar(20)         // "#000000" for UI
  description String?  @db.Text                // Description
  is_active   Boolean  @default(true)          // Is this rarity still used?
  created_at  DateTime @default(now()) @db.DateTime(0)
  updated_at  DateTime @updatedAt @db.DateTime(0)
  
  // Relations
  cards       Card[]   @relation("CardRarity")
  
  @@index([order_index])
  @@index([is_active])
  @@map("rarities")
}

// NEW: Subtype table
model Subtype {
  id          Int      @id @default(autoincrement())
  name        String   @unique                 // "Basic", "Stage 1", "Stage 2", "GX", "EX", "V", "VMAX"
  category    String   @db.VarChar(50)         // "Pokemon", "Trainer", "Energy"
  description String?  @db.Text                // What this subtype means
  order_index Int?     @default(0)             // For sorting
  is_active   Boolean  @default(true)          // Is this subtype still used?
  created_at  DateTime @default(now()) @db.DateTime(0)
  updated_at  DateTime @updatedAt @db.DateTime(0)
  
  // Relations
  cards       Card[]   @relation("CardSubtype")
  
  @@index([category])
  @@index([is_active])
  @@map("subtypes")
}

// NEW: Supertype table
model Supertype {
  id          Int      @id @default(autoincrement())
  name        String   @unique                 // "Pokémon", "Trainer", "Energy"
  description String?  @db.Text                // Description
  order_index Int?     @default(0)             // For sorting
  is_active   Boolean  @default(true)          // Is this supertype still used?
  created_at  DateTime @default(now()) @db.DateTime(0)
  updated_at  DateTime @updatedAt @db.DateTime(0)
  
  // Relations
  cards       Card[]   @relation("CardSupertype")
  
  @@index([order_index])
  @@index([is_active])
  @@map("supertypes")
}

// CARD TYPE MODEL - Separate table for type properties
model CardType {
  id              Int      @id @default(autoincrement())
  name            String   @unique @db.VarChar(50)    // "Fire", "Water", "Grass", etc.
  category        String   @db.VarChar(50)            // "Energy", "Pokemon", "Trainer"
  color           String?  @db.VarChar(20)            // "#FF6666" - hex color for UI
  symbol          String?  @db.VarChar(10)            // "🔥", "💧", "🌿" - emoji or symbol
  description     String?  @db.Text                   // Type description
  weakness_to     String?  @db.VarChar(50)            // What type this is weak to
  resistant_to    String?  @db.VarChar(50)            // What type this resists
  super_effective Json?                               // ["Grass", "Bug"] - types this is strong against
  not_effective   Json?                               // ["Fire"] - types this is weak against
  energy_symbol   String?  @db.VarChar(255)           // URL to energy symbol image
  type_order      Int?     @default(0)                // Order for UI display
  is_active       Boolean  @default(true)             // Is this type currently active?
  created_at      DateTime @default(now()) @db.DateTime(0)
  updated_at      DateTime @updatedAt @db.DateTime(0)
  
  // Relations
  primaryCards    Card[]   @relation("CardPrimaryType")
  secondaryCards  Card[]   @relation("CardSecondaryType")
  
  @@index([category])
  @@index([is_active])
  @@index([type_order])
  @@map("card_types")
}

enum CardSource {
  API
  MANUAL
  MIXED
}

// ENHANCED CARD MODEL with new foreign key relationships
model Card {
  id              Int        @id @default(autoincrement())
  
  // Basic card info
  name            String     @db.VarChar(255)
  set_name        String     @db.VarChar(255)
  set_number      String?    @db.VarChar(50)
  rarity          String     @db.VarChar(50)     // Keep as string for display
  card_type       String?    @db.VarChar(50)     // Keep as string for display
  hp              Int?
  image_url       String?    @db.VarChar(500)
  small_image_url String?    @db.VarChar(500)
  tcg_id          String?    @db.VarChar(255)
  
  // Pokemon TCG API fields
  api_id          String?    @unique @db.VarChar(100)
  supertype       String?    @db.VarChar(50)     // Keep as string for display
  subtypes        Json?                          // Array of subtypes from API
  
  // NEW: Foreign key relationships to new tables
  set_id          String?                        // Reference to PokemonSet.id
  rarity_id       Int?                           // Reference to Rarity.id
  subtype_id      Int?                           // Reference to Subtype.id (primary subtype)
  supertype_id    Int?                           // Reference to Supertype.id
  
  // NEW: Relations to new tables
  pokemonSet      PokemonSet? @relation("SetCards", fields: [set_id], references: [id])
  rarity_ref      Rarity?     @relation("CardRarity", fields: [rarity_id], references: [id])
  subtype_ref     Subtype?    @relation("CardSubtype", fields: [subtype_id], references: [id])
  supertype_ref   Supertype?  @relation("CardSupertype", fields: [supertype_id], references: [id])
  
  // TYPE RELATIONSHIPS - Link to CardType table
  primary_type_id   Int?                         // Main type (Fire, Water, etc.)
  primary_type      CardType? @relation("CardPrimaryType", fields: [primary_type_id], references: [id])
  secondary_type_id Int?                         // Secondary type for dual-type Pokemon
  secondary_type    CardType? @relation("CardSecondaryType", fields: [secondary_type_id], references: [id])
  
  // TYPE PROPERTIES from API (as backup/additional data)
  types           Json?                          // ["Fire", "Flying"] - raw API data
  weakness_type   String?    @db.VarChar(50)     // "Water" - weakness type
  weakness_value  String?    @db.VarChar(20)     // "×2", "+20" - weakness modifier
  resistance_type String?    @db.VarChar(50)     // "Fighting" - resistance type  
  resistance_value String?   @db.VarChar(20)     // "-20", "-30" - resistance modifier
  retreat_cost    Json?                          // ["Colorless", "Colorless"] - retreat energy types
  retreat_cost_count Int?                        // 2 - number of energy needed to retreat
  
  // POKEMON-SPECIFIC PROPERTIES
  evolves_from    String?    @db.VarChar(255)    // "Charmeleon" - evolution source
  evolves_to      Json?                          // ["Charizard"] - what this evolves into
  evolution_stage String?    @db.VarChar(50)     // "Basic", "Stage 1", "Stage 2"
  pokemon_type    String?    @db.VarChar(100)    // "Flame Pokémon", "Mouse Pokémon" - species type
  
  // ABILITIES AND ATTACKS
  abilities       Json?                          // [{"name": "Blaze", "text": "...", "type": "Ability"}]
  attacks         Json?                          // [{"name": "Fire Blast", "cost": ["Fire", "Fire"], "damage": "120", "text": "..."}]
  
  // CARD DETAILS
  artist          String?    @db.VarChar(255)
  flavor_text     String?    @db.Text
  national_pokedex_numbers Json?                 // [6] - Pokedex numbers
  regulation_mark String?    @db.VarChar(10)     // "D", "E", "F" - tournament regulation
  
  // MARKET DATA
  tcgplayer_prices Json?                         // Complete TCGPlayer pricing data
  cardmarket_prices Json?                        // Complete Cardmarket pricing data
  market_price    Decimal?   @db.Decimal(10, 2) // Current market price
  price_trend     String?    @db.VarChar(20)     // "up", "down", "stable"
  last_price_update DateTime?                    // When price was last updated
  
  // LEGALITIES AND FORMATS
  legalities      Json?                          // {"standard": "Legal", "expanded": "Legal"}
  tournament_legal Boolean   @default(true)      // Is this card tournament legal?
  banned_formats  Json?                          // ["Standard"] - formats where banned
  
  // CARD CONDITION AND GRADING
  condition_notes String?    @db.Text           // Detailed condition description
  grading_company String?    @db.VarChar(50)    // "PSA", "BGS", "CGC"
  grade_score     String?    @db.VarChar(10)    // "10", "9.5", "Mint"
  grade_date      DateTime?                     // When card was graded
  
  // RARITY AND COLLECTIBILITY
  rarity_symbol   String?    @db.VarChar(20)    // "●", "◆", "★" - rarity symbols
  holographic     Boolean    @default(false)    // Is this a holo card?
  reverse_holo    Boolean    @default(false)    // Is this reverse holo?
  first_edition   Boolean    @default(false)    // Is this first edition?
  shadowless      Boolean    @default(false)    // Is this shadowless (Base Set)
  promo           Boolean    @default(false)    // Is this a promo card?
  secret_rare     Boolean    @default(false)    // Is this a secret rare?
  
  // SOURCE AND SYNC INFO
  source          CardSource @default(MANUAL)
  api_updated_at  DateTime?
  sync_enabled    Boolean    @default(true)     // Should this card sync with API?
  last_sync       DateTime?                     // Last successful API sync
  
  // METADATA
  tags            Json?                          // ["popular", "meta", "vintage"] - custom tags
  notes           String?    @db.Text          // Admin/owner notes
  featured        Boolean    @default(false)    // Featured card on homepage?
  view_count      Int        @default(0)        // How many times viewed
  
  // Timestamps
  created_at      DateTime   @default(now()) @db.DateTime(0)
  updated_at      DateTime   @updatedAt @db.DateTime(0)
  
  // Relations
  userCards       UserCard[] @relation("CardUserCards")
  
  // Indexes
  @@index([api_id])
  @@index([name])
  @@index([set_name])
  @@index([source])
  @@index([card_type])
  @@index([rarity])
  @@index([market_price])
  @@index([tournament_legal])
  @@index([featured])
  @@index([primary_type_id])
  @@index([secondary_type_id])
  @@index([set_id])
  @@index([rarity_id])
  @@index([subtype_id])
  @@index([supertype_id])
  @@map("cards")
}

model Product {
  product_id   Int            @id @default(autoincrement()) @map("product_id")
  retailer     String         @db.VarChar(255)
  title        String         @db.VarChar(255)
  url          String         @db.VarChar(255)
  image        String?        @db.VarChar(255)
  screenshot   String?        @db.VarChar(255)
  stock_status String         @map("stock_status") @db.VarChar(50)
  release_date DateTime?      @map("release_date") @db.Date
  tcin         String?        @unique(map: "tcin") @db.VarChar(20)
  priceHistory PriceHistory[]
  @@map("products")
}

model PriceHistory {
  id             Int      @id @default(autoincrement())
  product_id     Int      @map("product_id")
  retailer       String   @default("Unknown") @db.VarChar(50)
  price          Decimal  @db.Decimal(10, 2)
  recorded_at    DateTime @default(now()) @map("recorded_at") @db.DateTime(0)
  stock_status   String?  @map("stock_status") @db.VarChar(50)
  store_quantity Int?     @map("store_quantity")
  ship_quantity  Int?     @map("ship_quantity")
  product        Product  @relation(fields: [product_id], references: [product_id], onDelete: Cascade, onUpdate: NoAction, map: "priceHistory_ibfk_1")
  @@index([product_id, retailer, recorded_at], map: "idx_product_retailer_date")
  @@map("pricehistory")
}

model Watchlist {
  id             Int     @id @default(autoincrement())
  retailer_name  String  @map("retailer_name") @db.VarChar(255)
  product_url    String? @map("product_url") @db.VarChar(255)
  product_title  String  @map("product_title") @db.VarChar(255)
  price          Decimal @db.Decimal(10, 2)
  stock_quantity Int?    @map("stock_quantity")
  stock_status   String? @map("stock_status") @db.VarChar(50)
  user_id        Int     @map("user_id")
  user           User    @relation("UserWatchlist", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "watchlist_ibfk_1")
  @@index([user_id], map: "user_id")
  @@map("watchlist")
}

model Waitlist {
  id           Int       @id @default(autoincrement())
  email        String    @unique(map: "email") @db.VarChar(255)
  phone_number String?   @map("phone_number") @db.VarChar(20)
  name         String    @db.VarChar(255)
  created_at   DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  status       String?   @default("PENDING") @db.VarChar(50)
  source       String?   @default("WEBSITE") @db.VarChar(50)
  metadata     Json?
  @@map("waitlist")
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("userId")
  action    String
  timestamp DateTime @default(now())
  user      User     @relation("UserActivity", fields: [userId], references: [id], onDelete: Cascade, map: "ActivityLog_userId_fkey")
  @@index([userId], map: "ActivityLog_userId_fkey")
  @@map("activitylog")
}

model ResetToken {
  id      Int      @id @default(autoincrement())
  email   String   @db.VarChar(255)
  token   String   @unique(map: "token") @db.VarChar(64)
  expires DateTime @db.DateTime(0)
  @@index([expires], map: "idx_expires")
  @@index([token], map: "idx_token")
  @@map("reset_tokens")
}

model UserCard {
  id            Int                  @id @default(autoincrement())
  owner_id      Int                  @map("owner_id")
  card_id       Int                  @map("card_id")
  condition     String?              @db.VarChar(50)
  is_for_sale   Boolean              @default(false) @map("is_for_sale")
  sale_type     String?              @map("sale_type") @db.VarChar(50)
  fixed_price   Decimal?             @map("fixed_price") @db.Decimal(10, 2)
  reserve_price Decimal?             @map("reserve_price") @db.Decimal(10, 2)
  auction_end   DateTime?            @map("auction_end") @db.DateTime(0)
  is_sold       Boolean              @default(false) @map("is_sold")
  notes         String?              @db.VarChar(255)
  acquired_date DateTime?            @map("acquired_date") @db.DateTime(0)
  created_at    DateTime             @default(now()) @db.DateTime(0)
  
  // Relations
  owner         User                 @relation("UserToUserCard", fields: [owner_id], references: [id], onDelete: Cascade, map: "userCard_ibfk_1")
  card          Card                 @relation("CardUserCards", fields: [card_id], references: [id], onDelete: Cascade, map: "userCard_ibfk_2")
  bids          Bid[]                @relation("UserCardBids")
  history       CardTransactionHistory[] @relation("UserCardHistory")
  
  @@index([owner_id], map: "owner_id")
  @@index([card_id], map: "card_id")
  @@index([is_for_sale])
  @@index([is_sold])
  @@map("user_cards")
}

model Bid {
  id          Int      @id @default(autoincrement())
  userCardId  Int
  userCard    UserCard @relation("UserCardBids", fields: [userCardId], references: [id])
  bidderId    Int
  bidder      User     @relation("BidToUser", fields: [bidderId], references: [id])
  amount      Float
  is_active   Boolean  @default(true)
  createdAt   DateTime @default(now())
  @@map("bids")
}

model CardTransactionHistory {
  id          Int      @id @default(autoincrement())
  userCardId  Int
  userCard    UserCard @relation("UserCardHistory", fields: [userCardId], references: [id], onDelete: Cascade)
  fromUserId  Int?
  fromUser    User?    @relation("HistoryFromUser", fields: [fromUserId], references: [id])
  toUserId    Int?
  toUser      User?    @relation("HistoryToUser", fields: [toUserId], references: [id])
  created_at  DateTime @default(now()) @db.DateTime(0)
  action      String   @db.VarChar(50)
  notes       String?  @db.VarChar(255)
  @@map("card_transaction_history")
}

model UserWallet {
  id             Int               @id @default(autoincrement())
  user_id        Int               @unique
  user           User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  balance        Decimal           @db.Decimal(10, 2)
  frozen_balance Decimal           @db.Decimal(10, 2)
  created_at     DateTime          @default(now()) @db.DateTime(0)
  updated_at     DateTime          @updatedAt @db.DateTime(0)
  transactions   WalletTransaction[] @relation("UserWalletTransactions")
  @@map("user_wallets")
}

model WalletTransaction {
  id              Int      @id @default(autoincrement())
  user_id         Int
  user            User     @relation("UserWalletTransaction", fields: [user_id], references: [id], onDelete: Cascade)
  wallet_id       Int
  wallet          UserWallet @relation("UserWalletTransactions", fields: [wallet_id], references: [id], onDelete: Cascade)
  transaction_type String   @db.VarChar(50)
  amount          Decimal  @db.Decimal(10, 2)
  balance_before  Decimal  @db.Decimal(10, 2)
  balance_after   Decimal  @db.Decimal(10, 2)
  description     String?  @db.VarChar(255)
  reference_type  String   @db.VarChar(50)
  reference_id    Int?
  admin_id        Int?
  created_at      DateTime @default(now()) @db.DateTime(0)
  @@map("wallet_transactions")
}

model Notification {
  id          Int      @id @default(autoincrement())
  user_id     Int
  user        User     @relation("UserNotifications", fields: [user_id], references: [id], onDelete: Cascade)
  type        String   @db.VarChar(50)
  title       String   @db.VarChar(255)
  message     String   @db.Text
  data        Json?
  read        Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  @@index([user_id, read])
  @@index([created_at])
  @@map("notifications")
}
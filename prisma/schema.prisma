generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                    Int       @id @default(autoincrement())
  email                 String    @unique(map: "email") @db.VarChar(255)
  name                  String    @db.VarChar(255)
  password              String    @db.VarChar(255)
  role                  String    @default("user") @db.VarChar(50)
  subscriptionStatus    String    @default("inactive") @map("subscriptionStatus") @db.VarChar(50)
  last_login_at         DateTime? @map("last_login_at") @db.DateTime(0)
  discord_access_token  String?   @map("discord_access_token") @db.VarChar(255)
  discord_refresh_token String?   @map("discord_refresh_token") @db.VarChar(255)
  google_access_token   String?   @map("google_access_token") @db.VarChar(255)
  google_refresh_token  String?   @map("google_refresh_token") @db.VarChar(255)
  google_scopes         String?   @map("google_scopes") @db.VarChar(255)
  registeredAt          DateTime  @default(now()) @map("registeredAt") @db.DateTime(0)
  is_verified           Int?      @default(0) @map("is_verified") @db.TinyInt
  verification_code     String?   @map("verification_code") @db.VarChar(10)

  // Relationships
  userCards             UserCard[]
  wallet                UserWallet?
  activityLogs          ActivityLog[]
  bids                  Bid[]
  cardTransactionsFrom  CardTransactionHistory[] @relation("FromUser")
  cardTransactionsTo    CardTransactionHistory[] @relation("ToUser")
  walletTransactions    WalletTransaction[]
  notifications         Notification[]
  watchlist             Watchlist[]

  @@map("users")
}

model PokemonSet {
  id             String    @id
  name           String    @unique
  series         String
  printed_total  Int?
  total          Int?
  legalities     Json?
  ptcgo_code     String?
  release_date   String
  images         Json?
  api_updated_at DateTime?
  created_at     DateTime  @default(now()) @db.DateTime(0)
  updated_at     DateTime  @updatedAt @db.DateTime(0)

  // Relationships
  cards          Card[]

  @@index([series])
  @@index([release_date])
  @@map("pokemon_sets")
}

model Rarity {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  symbol      String?  @db.VarChar(20)
  order_index Int?     @default(0)
  color       String?  @db.VarChar(20)
  description String?  @db.Text
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now()) @db.DateTime(0)
  updated_at  DateTime @updatedAt @db.DateTime(0)

  // Relationships
  cards       Card[]

  @@index([order_index])
  @@index([is_active])
  @@map("rarities")
}

model Subtype {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  category    String   @db.VarChar(50)
  description String?  @db.Text
  order_index Int?     @default(0)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now()) @db.DateTime(0)
  updated_at  DateTime @updatedAt @db.DateTime(0)

  // Relationships
  cards       Card[]

  @@index([category])
  @@index([is_active])
  @@map("subtypes")
}

model Supertype {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?  @db.Text
  order_index Int?     @default(0)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now()) @db.DateTime(0)
  updated_at  DateTime @updatedAt @db.DateTime(0)

  // Relationships
  cards       Card[]

  @@index([order_index])
  @@index([is_active])
  @@map("supertypes")
}

model CardType {
  id              Int      @id @default(autoincrement())
  name            String   @unique @db.VarChar(50)
  category        String   @db.VarChar(50)
  color           String?  @db.VarChar(20)
  symbol          String?  @db.VarChar(10)
  description     String?  @db.Text
  weakness_to     String?  @db.VarChar(50)
  resistant_to    String?  @db.VarChar(50)
  super_effective Json?
  not_effective   Json?
  energy_symbol   String?  @db.VarChar(255)
  type_order      Int?     @default(0)
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now()) @db.DateTime(0)
  updated_at      DateTime @updatedAt @db.DateTime(0)

  @@index([category])
  @@index([is_active])
  @@index([type_order])
  @@map("card_types")
}

model Card {
  id                       Int        @id @default(autoincrement())
  name                     String     @db.VarChar(255)
  set_name                 String     @db.VarChar(255)
  set_number               String?    @db.VarChar(50)
  rarity                   String     @db.VarChar(50)
  card_type                String?    @db.VarChar(50)
  subtype                  String?    @db.VarChar(255)
  hp                       Int?
  image_url                String?    @db.VarChar(500)
  small_image_url          String?    @db.VarChar(500)
  tcg_id                   String?    @db.VarChar(255)
  api_id                   String?    @unique @db.VarChar(100)
  supertype                String?    @db.VarChar(50)
  subtypes                 Json?
  set_id                   String?
  rarity_id                Int?
  subtype_id               Int?
  supertype_id             Int?
  primary_type_id          Int?
  secondary_type_id        Int?
  types                    Json?
  weakness_type            String?    @db.VarChar(50)
  weakness_value           String?    @db.VarChar(20)
  resistance_type          String?    @db.VarChar(50)
  resistance_value         String?    @db.VarChar(20)
  retreat_cost             Json?
  retreat_cost_count       Int?
  evolves_from             String?    @db.VarChar(255)
  evolves_to               Json?
  evolution_stage          String?    @db.VarChar(50)
  pokemon_type             String?    @db.VarChar(100)
  abilities                Json?
  attacks                  Json?
  artist                   String?    @db.VarChar(255)
  flavor_text              String?    @db.Text
  national_pokedex_numbers Json?
  regulation_mark          String?    @db.VarChar(10)
  tcgplayer_prices         Json?
  cardmarket_prices        Json?
  market_price             Decimal?   @db.Decimal(10, 2)
  price_trend              String?    @db.VarChar(20)
  last_price_update        DateTime?
  legalities               Json?
  tournament_legal         Boolean    @default(true)
  banned_formats           Json?
  condition_notes          String?    @db.Text
  grading_company          String?    @db.VarChar(50)
  grade_score              String?    @db.VarChar(10)
  grade_date               DateTime?
  rarity_symbol            String?    @db.VarChar(20)
  holographic              Boolean    @default(false)
  reverse_holo             Boolean    @default(false)
  first_edition            Boolean    @default(false)
  shadowless               Boolean    @default(false)
  promo                    Boolean    @default(false)
  secret_rare              Boolean    @default(false)
  source                   CardSource @default(MANUAL)
  api_updated_at           DateTime?
  sync_enabled             Boolean    @default(true)
  last_sync                DateTime?
  tags                     Json?
  notes                    String?    @db.Text
  featured                 Boolean    @default(false)
  view_count               Int        @default(0)
  created_at               DateTime   @default(now()) @db.DateTime(0)
  updated_at               DateTime   @updatedAt @db.DateTime(0)

  // Relationships - THIS IS WHAT WAS MISSING!
  pokemonSet      PokemonSet?   @relation(fields: [set_id], references: [id])
  rarity_ref      Rarity?       @relation(fields: [rarity_id], references: [id])
  subtype_ref     Subtype?      @relation(fields: [subtype_id], references: [id])
  supertype_ref   Supertype?    @relation(fields: [supertype_id], references: [id])
  userCards       UserCard[]    // This relationship was missing!
  priceHistory    price_history[]

  @@index([api_id])
  @@index([name])
  @@index([set_name])
  @@index([source])
  @@index([card_type])
  @@index([rarity])
  @@index([market_price])
  @@index([tournament_legal])
  @@index([featured])
  @@index([primary_type_id])
  @@index([secondary_type_id])
  @@index([set_id])
  @@index([rarity_id])
  @@index([subtype_id])
  @@index([supertype_id])
  @@index([sync_enabled])
  @@index([last_price_update])
  @@map("cards")
}

model PriceHistory {
  id             Int      @id @default(autoincrement())
  product_id     Int
  retailer       String   @default("Unknown") @db.VarChar(50)
  price          Decimal  @db.Decimal(10, 2)
  recorded_at    DateTime @default(now()) @map("recorded_at") @db.DateTime(0)
  stock_status   String?  @map("stock_status") @db.VarChar(50)
  store_quantity Int?
  ship_quantity  Int?

  @@index([product_id, retailer, recorded_at], map: "idx_product_retailer_date")
  @@map("pricehistory")
}

model Product {
  product_id   Int       @id @default(autoincrement()) @map("product_id")
  retailer     String    @db.VarChar(255)
  title        String    @db.VarChar(255)
  url          String    @db.VarChar(255)
  image        String?   @db.VarChar(255)
  screenshot   String?   @db.VarChar(255)
  stock_status String    @map("stock_status") @db.VarChar(50)
  release_date DateTime? @map("release_date") @db.Date
  tcin         String?   @unique(map: "tcin") @db.VarChar(20)

  @@map("products")
}

model Watchlist {
  id             Int     @id @default(autoincrement())
  retailer_name  String  @map("retailer_name") @db.VarChar(255)
  product_url    String? @map("product_url") @db.VarChar(255)
  product_title  String  @map("product_title") @db.VarChar(255)
  price          Decimal @db.Decimal(10, 2)
  stock_quantity Int?    @map("stock_quantity")
  stock_status   String? @map("stock_status") @db.VarChar(50)
  user_id        Int     @map("user_id")

  // Relationships
  user           User    @relation(fields: [user_id], references: [id])

  @@index([user_id], map: "user_id")
  @@map("watchlist")
}

model Waitlist {
  id           Int       @id @default(autoincrement())
  email        String    @unique(map: "email") @db.VarChar(255)
  phone_number String?   @map("phone_number") @db.VarChar(20)
  name         String    @db.VarChar(255)
  created_at   DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  status       String?   @default("PENDING") @db.VarChar(50)
  source       String?   @default("WEBSITE") @db.VarChar(50)
  metadata     Json?

  @@map("waitlist")
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("userId")
  action    String
  timestamp DateTime @default(now())

  // Relationships
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId], map: "ActivityLog_userId_fkey")
  @@map("activitylog")
}

model ResetToken {
  id      Int      @id @default(autoincrement())
  email   String   @db.VarChar(255)
  token   String   @unique(map: "token") @db.VarChar(64)
  expires DateTime @db.DateTime(0)

  @@index([expires], map: "idx_expires")
  @@index([token], map: "idx_token")
  @@map("reset_tokens")
}

model UserCard {
  id            Int       @id @default(autoincrement())
  owner_id      Int       @map("owner_id")
  card_id       Int       @map("card_id")
  condition     String?   @db.VarChar(50)
  is_for_sale   Boolean   @default(false) @map("is_for_sale")
  sale_type     String?   @map("sale_type") @db.VarChar(50)
  fixed_price   Decimal?  @map("fixed_price") @db.Decimal(10, 2)
  reserve_price Decimal?  @map("reserve_price") @db.Decimal(10, 2)
  auction_end   DateTime? @map("auction_end") @db.DateTime(0)
  is_sold       Boolean   @default(false) @map("is_sold")
  notes         String?   @db.VarChar(255)
  acquired_date DateTime? @map("acquired_date") @db.DateTime(0)
  created_at    DateTime  @default(now()) @db.DateTime(0)

  // Relationships
  owner         User      @relation(fields: [owner_id], references: [id])
  card          Card      @relation(fields: [card_id], references: [id])
  bids          Bid[]
  transactionHistory CardTransactionHistory[]

  @@index([owner_id], map: "owner_id")
  @@index([card_id], map: "card_id")
  @@index([is_for_sale])
  @@index([is_sold])
  @@map("user_cards")
}

model Bid {
  id         Int      @id @default(autoincrement())
  userCardId Int
  bidderId   Int
  amount     Float
  is_active  Boolean  @default(true)
  createdAt  DateTime @default(now())

  // Relationships
  userCard   UserCard @relation(fields: [userCardId], references: [id])
  bidder     User     @relation(fields: [bidderId], references: [id])

  @@index([bidderId], map: "bids_bidderId_fkey")
  @@index([userCardId], map: "bids_userCardId_fkey")
  @@map("bids")
}

model CardTransactionHistory {
  id         Int      @id @default(autoincrement())
  userCardId Int
  fromUserId Int?
  toUserId   Int?
  created_at DateTime @default(now()) @db.DateTime(0)
  action     String   @db.VarChar(50)
  notes      String?  @db.VarChar(255)

  // Relationships
  userCard   UserCard @relation(fields: [userCardId], references: [id])
  fromUser   User?    @relation("FromUser", fields: [fromUserId], references: [id])
  toUser     User?    @relation("ToUser", fields: [toUserId], references: [id])

  @@index([fromUserId], map: "card_transaction_history_fromUserId_fkey")
  @@index([toUserId], map: "card_transaction_history_toUserId_fkey")
  @@index([userCardId], map: "card_transaction_history_userCardId_fkey")
  @@map("card_transaction_history")
}

model UserWallet {
  id             Int      @id @default(autoincrement())
  user_id        Int      @unique
  balance        Decimal  @db.Decimal(10, 2)
  frozen_balance Decimal  @db.Decimal(10, 2)
  created_at     DateTime @default(now()) @db.DateTime(0)
  updated_at     DateTime @updatedAt @db.DateTime(0)

  // Relationships
  user           User     @relation(fields: [user_id], references: [id])
  transactions   WalletTransaction[]

  @@map("user_wallets")
}

model WalletTransaction {
  id               Int      @id @default(autoincrement())
  user_id          Int
  wallet_id        Int
  transaction_type String   @db.VarChar(50)
  amount           Decimal  @db.Decimal(10, 2)
  balance_before   Decimal  @db.Decimal(10, 2)
  balance_after    Decimal  @db.Decimal(10, 2)
  description      String?  @db.VarChar(255)
  reference_type   String   @db.VarChar(50)
  reference_id     Int?
  admin_id         Int?
  created_at       DateTime @default(now()) @db.DateTime(0)

  // Relationships
  user             User       @relation(fields: [user_id], references: [id])
  wallet           UserWallet @relation(fields: [wallet_id], references: [id])

  @@index([user_id], map: "wallet_transactions_user_id_fkey")
  @@index([wallet_id], map: "wallet_transactions_wallet_id_fkey")
  @@map("wallet_transactions")
}

model Notification {
  id         Int      @id @default(autoincrement())
  user_id    Int
  type       String   @db.VarChar(50)
  title      String   @db.VarChar(255)
  message    String   @db.Text
  data       Json?
  read       Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relationships
  user       User     @relation(fields: [user_id], references: [id])

  @@index([user_id, read])
  @@index([created_at])
  @@map("notifications")
}

model price_history {
  id          Int      @id @default(autoincrement())
  card_id     Int
  price       Decimal  @db.Decimal(10, 2)
  source      String   @default("manual") @db.VarChar(50)
  recorded_at DateTime @default(now()) @db.DateTime(0)
  metadata    Json?
  created_at  DateTime @default(now()) @db.DateTime(0)

  // Relationships
  card        Card     @relation(fields: [card_id], references: [id])

  @@index([card_id, recorded_at], map: "idx_card_date")
  @@index([card_id], map: "idx_card_id")
  @@index([recorded_at], map: "idx_recorded_at")
  @@index([source], map: "idx_source")
}

enum CardSource {
  API
  MANUAL
  MIXED
}
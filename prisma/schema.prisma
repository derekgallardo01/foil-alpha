generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                    Int       @id @default(autoincrement())
  email                 String    @unique(map: "email") @db.VarChar(255)
  name                  String    @db.VarChar(255)
  password              String    @db.VarChar(255)
  role                  String    @default("user") @db.VarChar(50)
  subscriptionStatus    String    @default("inactive") @map("subscriptionStatus") @db.VarChar(50)
  last_login_at         DateTime? @map("last_login_at") @db.DateTime(0)
  discord_access_token  String?   @map("discord_access_token") @db.VarChar(255)
  discord_refresh_token String?   @map("discord_refresh_token") @db.VarChar(255)
  google_access_token   String?   @map("google_access_token") @db.VarChar(255)
  google_refresh_token  String?   @map("google_refresh_token") @db.VarChar(255)
  google_scopes         String?   @map("google_scopes") @db.VarChar(255)
  registeredAt          DateTime  @default(now()) @map("registeredAt") @db.DateTime(0)
  is_verified           Int?      @default(0) @map("is_verified") @db.TinyInt
  verification_code     String?   @map("verification_code") @db.VarChar(10)

  @@map("users")
}

model Card {
  id                    Int        @id @default(autoincrement())
  price_tracker_id      String     @unique @db.VarChar(100)
  tcg_player_id         String?    @db.VarChar(100)
  name                  String     @db.VarChar(255)
  card_number           String     @db.VarChar(50)
  total_set_number      String?    @db.VarChar(50)
  rarity                String     @db.VarChar(100)
  card_type             String?    @db.VarChar(100)
  hp                    Int?
  stage                 String?    @db.VarChar(50)
  set_id                String     @db.VarChar(100)
  set_name              String     @db.VarChar(255)
  image_url             String?    @db.VarChar(500)
  market_price          Decimal?   @db.Decimal(10, 2)
  price_listings        Int?
  primary_condition     String?    @db.VarChar(50)
  price_last_updated    DateTime?  @db.DateTime(0)
  tcg_player_url        String?    @db.VarChar(500)
  artist                String?    @db.VarChar(255)
  retreat_cost          Int?
  data_completeness     Int?       @default(0)
  needs_detailed_scrape Boolean?   @default(false)
  last_scraped_at       DateTime?  @db.DateTime(0)
  attacks_data          Json?
  weakness_data         Json?
  resistance_data       Json?
  prices_data           Json?
  ebay_data             Json?
  price_history_data    Json?
  price_source          String?    @db.VarChar(50)
  last_updated          DateTime?  @db.DateTime(0)
  sync_enabled          Boolean    @default(true)
  sync_errors           Int        @default(0)
  source                CardSource @default(API)
  featured              Boolean    @default(false)
  view_count            Int        @default(0)
  notes                 String?    @db.Text
  created_at            DateTime   @default(now()) @db.DateTime(0)
  updated_at            DateTime   @updatedAt @db.DateTime(0)

  // Multi-TCG + sealed support (added for external collection imports, e.g. Collectr)
  product_type          String     @default("CARD") @db.VarChar(20) // CARD | SEALED
  tcg                   String?    @db.VarChar(50)
  external_source       String?    @db.VarChar(30)
  external_id           String?    @db.VarChar(100)

  @@unique([external_source, external_id], map: "uniq_cards_external")
  @@index([price_tracker_id])
  @@index([tcg_player_id])
  @@index([name])
  @@index([set_id])
  @@index([set_name])
  @@index([rarity])
  @@index([card_type])
  @@index([market_price])
  @@index([sync_enabled])
  @@index([last_updated])
  @@index([last_scraped_at])
  @@map("cards")
}

model Watchlist {
  id             Int     @id @default(autoincrement())
  retailer_name  String  @map("retailer_name") @db.VarChar(255)
  product_url    String? @map("product_url") @db.VarChar(255)
  product_title  String  @map("product_title") @db.VarChar(255)
  price          Decimal @db.Decimal(10, 2)
  stock_quantity Int?    @map("stock_quantity")
  stock_status   String? @map("stock_status") @db.VarChar(50)
  user_id        Int     @map("user_id")

  @@index([user_id], map: "user_id")
  @@map("watchlist")
}

model Waitlist {
  id           Int       @id @default(autoincrement())
  email        String    @unique(map: "email") @db.VarChar(255)
  phone_number String?   @map("phone_number") @db.VarChar(20)
  name         String    @db.VarChar(255)
  created_at   DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  status       String?   @default("PENDING") @db.VarChar(50)
  source       String?   @default("WEBSITE") @db.VarChar(50)
  metadata     Json?

  @@map("waitlist")
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("userId")
  action    String
  timestamp DateTime @default(now())

  @@index([userId], map: "ActivityLog_userId_fkey")
  @@map("activitylog")
}

model ResetToken {
  id      Int      @id @default(autoincrement())
  email   String   @db.VarChar(255)
  token   String   @unique(map: "token") @db.VarChar(64)
  expires DateTime @db.DateTime(0)

  @@index([expires], map: "idx_expires")
  @@index([token], map: "idx_token")
  @@map("reset_tokens")
}

model UserCard {
  id            Int       @id @default(autoincrement())
  owner_id      Int       @map("owner_id")
  card_id       Int       @map("card_id")
  condition     String?   @db.VarChar(50)
  is_for_sale   Boolean   @default(false) @map("is_for_sale")
  sale_type     String?   @map("sale_type") @db.VarChar(50)
  fixed_price   Decimal?  @map("fixed_price") @db.Decimal(10, 2)
  reserve_price Decimal?  @map("reserve_price") @db.Decimal(10, 2)
  auction_end   DateTime? @map("auction_end") @db.DateTime(0)
  is_sold       Boolean   @default(false) @map("is_sold")
  notes         String?   @db.VarChar(255)
  acquired_date DateTime? @map("acquired_date") @db.DateTime(0)
  created_at    DateTime  @default(now()) @db.DateTime(0)

  // Quantity + grading + external-import idempotency (e.g. Collectr)
  quantity              Int      @default(1)
  is_graded             Boolean  @default(false)
  grade_label           String?  @db.VarChar(50)
  acquired_market_price Decimal? @db.Decimal(10, 2)
  external_owned_id     String?  @unique(map: "uniq_uc_external_owned") @db.VarChar(100)

  @@index([owner_id])
  @@index([card_id])
  @@index([is_for_sale])
  @@index([is_sold])
  @@map("user_cards")
}

model Bid {
  id         Int      @id @default(autoincrement())
  userCardId Int
  bidderId   Int
  amount     Decimal  @db.Decimal(10, 2)
  is_active  Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([bidderId], map: "bids_bidderId_fkey")
  @@index([userCardId], map: "bids_userCardId_fkey")
  @@map("bids")
}

model CardTransactionHistory {
  id         Int      @id @default(autoincrement())
  userCardId Int
  fromUserId Int?
  toUserId   Int?
  created_at DateTime @default(now()) @db.DateTime(0)
  action     String   @db.VarChar(50)
  notes      String?  @db.VarChar(255)

  @@index([fromUserId], map: "card_transaction_history_fromUserId_fkey")
  @@index([toUserId], map: "card_transaction_history_toUserId_fkey")
  @@index([userCardId], map: "card_transaction_history_userCardId_fkey")
  @@map("card_transaction_history")
}

model UserWallet {
  id             Int      @id @default(autoincrement())
  user_id        Int      @unique
  balance        Decimal  @db.Decimal(10, 2)
  frozen_balance Decimal  @db.Decimal(10, 2)
  created_at     DateTime @default(now()) @db.DateTime(0)
  updated_at     DateTime @updatedAt @db.DateTime(0)

  @@map("user_wallets")
}

model WalletTransaction {
  id               Int      @id @default(autoincrement())
  user_id          Int
  wallet_id        Int
  transaction_type String   @db.VarChar(50)
  amount           Decimal  @db.Decimal(10, 2)
  balance_before   Decimal  @db.Decimal(10, 2)
  balance_after    Decimal  @db.Decimal(10, 2)
  description      String?  @db.VarChar(255)
  reference_type   String   @db.VarChar(50)
  reference_id     Int?
  admin_id         Int?
  created_at       DateTime @default(now()) @db.DateTime(0)

  @@index([user_id], map: "wallet_transactions_user_id_fkey")
  @@index([wallet_id], map: "wallet_transactions_wallet_id_fkey")
  @@map("wallet_transactions")
}

model Notification {
  id         Int      @id @default(autoincrement())
  user_id    Int
  type       String   @db.VarChar(50)
  title      String   @db.VarChar(255)
  message    String   @db.Text
  data       Json?
  read       Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([user_id, read])
  @@index([created_at])
  @@map("notifications")
}

model price_history {
  id            Int      @id @default(autoincrement())
  card_id       Int
  price         Decimal  @db.Decimal(10, 2)
  source        String   @default("pokemon_price_tracker_v2") @db.VarChar(50)
  recorded_at   DateTime @default(now()) @db.DateTime(0)
  price_type    String?  @db.VarChar(50)
  condition     String?  @db.VarChar(50)
  tcg_player_id String?  @db.VarChar(100)
  listing_count Int?
  volume        Int?
  data_source   String?  @db.VarChar(50)
  metadata      Json?
  created_at    DateTime @default(now()) @db.DateTime(0)

  @@index([card_id, recorded_at], map: "idx_card_date")
  @@index([card_id], map: "idx_card_id")
  @@index([recorded_at], map: "idx_recorded_at")
  @@index([source], map: "idx_source")
  @@index([tcg_player_id], map: "idx_tcg_player_id")
}

model Transaction {
  id               Int      @id @default(autoincrement())
  user_card_id     Int      @map("user_card_id")
  buyer_id         Int      @map("buyer_id")
  seller_id        Int      @map("seller_id")
  amount           Decimal  @db.Decimal(10, 2)
  transaction_type String   @map("transaction_type") @db.VarChar(50)
  status           String   @db.VarChar(50)
  notes            String?  @db.Text
  created_at       DateTime @default(now()) @db.DateTime(0)
  updated_at       DateTime @updatedAt @db.DateTime(0)

  @@index([user_card_id])
  @@index([buyer_id])
  @@index([seller_id])
  @@index([status])
  @@map("transactions")
}

model admin_wallet {
  id                      Int                       @id @default(autoincrement())
  wallet_type             admin_wallet_wallet_type? @default(PLATFORM)
  balance                 Decimal?                  @default(0.00) @db.Decimal(12, 2)
  total_commissions       Decimal?                  @default(0.00) @db.Decimal(12, 2)
  total_marketplace_sales Decimal?                  @default(0.00) @db.Decimal(12, 2)
  created_at              DateTime?                 @default(now()) @db.DateTime(0)
  updated_at              DateTime?                 @default(now()) @db.DateTime(0)
}

model admin_wallet_transactions {
  id               Int                                        @id @default(autoincrement())
  admin_wallet_id  Int
  transaction_type admin_wallet_transactions_transaction_type
  amount           Decimal                                    @db.Decimal(10, 2)
  balance_before   Decimal                                    @db.Decimal(12, 2)
  balance_after    Decimal                                    @db.Decimal(12, 2)
  description      String?                                    @db.VarChar(255)
  reference_type   String?                                    @db.VarChar(50)
  reference_id     Int?
  user_card_id     Int?
  buyer_id         Int?
  seller_id        Int?
  card_id          Int?
  commission_rate  Decimal?                                   @db.Decimal(5, 2)
  admin_id         Int?
  created_at       DateTime?                                  @default(now()) @db.DateTime(0)

  @@index([admin_wallet_id], map: "admin_wallet_id")
  @@index([created_at], map: "idx_created_at")
  @@index([reference_type, reference_id], map: "idx_reference")
  @@index([transaction_type], map: "idx_transaction_type")
}

model commission_settings {
  id              Int                              @id @default(autoincrement())
  setting_type    commission_settings_setting_type
  setting_key     String                           @db.VarChar(50)
  commission_rate Decimal                          @db.Decimal(5, 2)
  is_active       Boolean?                         @default(true)
  created_by      Int?
  created_at      DateTime?                        @default(now()) @db.DateTime(0)
  updated_at      DateTime?                        @default(now()) @db.DateTime(0)

  @@unique([setting_type, setting_key], map: "unique_setting")
  @@index([is_active], map: "idx_active")
  @@index([setting_type], map: "idx_setting_type")
}

model CatalogInventory {
  id                 Int       @id @default(autoincrement())
  card_id            Int       @unique(map: "unique_card_inventory") @map("card_id")
  quantity_available Int       @default(0) @map("quantity_available")
  quantity_sold      Int       @default(0) @map("quantity_sold")
  last_restock_date  DateTime? @map("last_restock_date") @db.DateTime(0)
  created_at         DateTime? @default(now()) @map("created_at") @db.DateTime(0)
  updated_at         DateTime? @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)

  @@index([quantity_available], map: "idx_quantity_available")
  @@map("catalog_inventory")
}

model PriceSyncLog {
  id                 Int      @id @default(autoincrement())
  sync_type          String   @db.VarChar(50)
  cards_processed    Int      @default(0)
  cards_updated      Int      @default(0)
  cards_failed       Int      @default(0)
  cards_skipped      Int      @default(0)
  total_api_requests Int      @default(0)
  api_errors         Int      @default(0)
  rate_limit_hits    Int      @default(0)
  start_time         DateTime @db.DateTime(0)
  end_time           DateTime @db.DateTime(0)
  duration_seconds   Int      @default(0)
  error_details      Json?
  performance_stats  Json?
  triggered_by       String?  @db.VarChar(100)
  created_at         DateTime @default(now()) @db.DateTime(0)

  @@index([sync_type])
  @@index([start_time])
  @@map("price_sync_logs")
}

/// Retail sealed-product tracking (the stock-checker / watchlist "bundles").
/// Accessed via raw SQL in /api/products; modeled here so the tables exist and
/// can be managed. Columns must match the raw SQL in src/app/api/products.
model Product {
  product_id   Int       @id
  tcin         String?   @unique @db.VarChar(50)
  retailer     String?   @db.VarChar(100)
  title        String?   @db.VarChar(500)
  url          String?   @db.VarChar(1000)
  image        String?   @db.VarChar(1000)
  screenshot   String?   @db.VarChar(1000)
  stock_status String?   @db.VarChar(100)
  release_date DateTime? @db.Date
  created_at   DateTime  @default(now()) @db.DateTime(0)

  @@map("products")
}

model RetailPriceHistory {
  id             Int      @id @default(autoincrement())
  product_id     Int
  retailer       String?  @db.VarChar(100)
  price          Decimal? @db.Decimal(10, 2)
  recorded_at    DateTime @default(now()) @db.DateTime(0)
  stock_status   String?  @db.VarChar(100)
  store_quantity Int?     @default(0)
  ship_quantity  Int?     @default(0)

  @@index([product_id], map: "idx_ph_product")
  @@index([recorded_at], map: "idx_ph_recorded")
  @@map("pricehistory")
}

enum CardSource {
  API
  MANUAL
  MIXED
}

enum admin_wallet_wallet_type {
  PLATFORM
}

enum commission_settings_setting_type {
  GLOBAL
  RARITY
}

enum admin_wallet_transactions_transaction_type {
  COMMISSION
  MARKETPLACE_SALE
  WITHDRAWAL
  ADJUSTMENT
}

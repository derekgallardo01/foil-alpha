import { google } from "googleapis";
import fs from "fs/promises";
import path from "path";
import dotenv from "dotenv";

type AuthError = {
  message: string;
  stack?: string;
  response?: {
    data?: any;
    status?: number;
  };
  code?: string;
};

type EnvironmentError = {
  message: string;
  stack?: string;
};

dotenv.config({ path: path.join(process.cwd(), ".env") });

// Debug logging for environment variables
console.log("Environment variables:");
console.log("GMAIL_TOKEN set:", !!process.env.GMAIL_TOKEN);
console.log("GMAIL_TOKEN length:", process.env.GMAIL_TOKEN?.length);

const credentialsPath = path.join(process.cwd(), "credentials.json");

try {
  // Verify environment variables
  if (!process.env.GMAIL_TOKEN) {
    throw new Error("GMAIL_TOKEN environment variable is not set");
  }
  console.log("Environment variables verified successfully");
} catch (error) {
  console.error("Environment variable error:", {
    message: (error as EnvironmentError).message,
    stack: (error as EnvironmentError).stack,
  });
  throw error;
}
const tokenPath = path.join(process.cwd(), "token.json");

console.log("Credentials path:", credentialsPath);
console.log("Token path:", tokenPath);

let credentials;
try {
  const credentialsData = await fs.readFile(credentialsPath, "utf8");
  credentials = JSON.parse(credentialsData);
  console.log("Credentials loaded successfully:", {
    client_id: credentials.web.client_id ? "set" : "unset",
    client_secret: credentials.web.client_secret ? "set" : "unset",
    redirect_uris: credentials.web.redirect_uris,
    project_id: credentials.web.project_id,
  });
} catch (error: unknown) {
  if (error instanceof Error) {
    console.error("Error loading credentials:", {
      message: error.message,
      stack: error.stack,
    });
  } else {
    console.error("Error loading credentials:", error);
  }
  throw new Error("Failed to load Gmail credentials");
}

let tokens;
try {
  // Always use token from .env since it's set
  if (!process.env.GMAIL_TOKEN) {
    throw new Error("GMAIL_TOKEN environment variable is not set");
  }
  tokens = JSON.parse(process.env.GMAIL_TOKEN);
  console.log("Tokens loaded from GMAIL_TOKEN environment variable");
  console.log("Tokens loaded successfully:", {
    access_token: tokens.access_token ? "set" : "unset",
    refresh_token: tokens.refresh_token ? "set" : "unset",
    scope: tokens.scope,
    expiry_date: tokens.expiry_date,
  });
} catch (error) {
  console.error("Error loading tokens:", {
    message: (error as Error).message,
    stack: (error as Error).stack,
  });
  throw new Error("Failed to load Gmail tokens");
}

const { client_id, client_secret, redirect_uris } = credentials.web;
const oAuth2Client = new google.auth.OAuth2(client_id, client_secret, redirect_uris[0]);

oAuth2Client.setCredentials(tokens);

console.log("OAuth2 client initialized with:");
console.log("  Client ID:", client_id ? "set" : "unset");
console.log("  Redirect URI:", redirect_uris[0]);
console.log("  Has refresh token:", !!tokens.refresh_token);

// Save refreshed tokens to token.json (if using file storage)
oAuth2Client.on("tokens", async (newTokens) => {
  console.log("New tokens received:", {
    access_token: newTokens.access_token ? "set" : "unset",
    refresh_token: newTokens.refresh_token ? "set" : "unset",
    expiry_date: newTokens.expiry_date,
  });
  if (!process.env.GMAIL_TOKEN) {
    try {
      await fs.writeFile(tokenPath, JSON.stringify({ ...tokens, ...newTokens }, null, 2));
      console.log("Tokens saved to:", tokenPath);
    } catch (error) {
      console.error("Error saving tokens:", {
        message: error.message,
        stack: error.stack,
      });
    }
  }
});

const gmail = google.gmail({ version: "v1", auth: oAuth2Client });

async function ensureValidToken() {
  const timestamp = new Date().toLocaleString("en-US", { timeZone: "America/New_York" });
  try {
    console.log(`[${timestamp}] Checking access token validity`);
    const { token } = await oAuth2Client.getAccessToken();
    if (!token) {
      throw new Error("No access token received");
    }
    console.log(`[${timestamp}] Access token valid`);
    return token;
  } catch (error) {
    console.error(`[${timestamp}] Error refreshing token:`, {
      message: (error as AuthError).message,
      stack: (error as AuthError).stack,
      response: (error as AuthError).response?.data,
    });
    if (error.message.includes("unauthorized_client")) {
      throw new Error(
        "Unauthorized client error. Regenerate token.json using generate-token.js and verify credentials match. If deployed, ensure GMAIL_TOKEN environment variable is set."
      );
    }
    throw new Error(`Failed to refresh access token: ${error.message}`);
  }
}

async function testGmailApi() {
  const timestamp = new Date().toLocaleString("en-US", { timeZone: "America/New_York" });
  try {
    await ensureValidToken();
    const result = await gmail.users.getProfile({ userId: "me" });
    console.log(`[${timestamp}] Gmail API test successful - profile retrieved:`, result.data);
    return result.data;
  } catch (error) {
    console.error(`[${timestamp}] Gmail API test failed:`, {
      message: (error as AuthError).message,
      stack: (error as AuthError).stack,
      response: (error as AuthError).response?.data,
    });
    throw error;
  }
}

async function sendEmail(to: string, subject: string, htmlContent: string) {
  const timestamp = new Date().toLocaleString("en-US", { timeZone: "America/New_York" });
  try {
    console.log(`[${timestamp}] Attempting to send email:`, {
      to,
      subject,
      contentLength: htmlContent.length,
    });

    await ensureValidToken();

    const message = [
      `To: ${to}`,
      `Subject: ${subject}`,
      "MIME-Version: 1.0",
      'Content-Type: text/html; charset="UTF-8"',
      "Content-Transfer-Encoding: base64",
      "",
      Buffer.from(htmlContent).toString("base64"),
    ].join("\n");

    const rawMessage = Buffer.from(message)
      .toString("base64")
      .replace(/\+/g, "-")
      .replace(/\//g, "_")
      .replace(/=+$/, "");

    console.log(`[${timestamp}] Raw message created (first 100 chars):`, rawMessage.substring(0, 100));

    const response = await gmail.users.messages.send({
      userId: "me",
      requestBody: {
        raw: rawMessage,
      },
    });

    console.log(`[${timestamp}] Email sent successfully:`, {
      id: response.data.id,
      threadId: response.data.threadId,
      labelIds: response.data.labelIds,
    });
    return response.data;
  } catch (error) {
    console.error(`[${timestamp}] Email sending failed:`, {
      message: (error as AuthError).message,
      stack: (error as AuthError).stack,
      response: (error as AuthError).response?.data,
      code: (error as AuthError).code,
      status: (error as AuthError).response?.status,
    });
    throw new Error(`Failed to send email: ${error.message}`);
  }
}

export { testGmailApi, sendEmail };

// Test function - only runs if this file is executed directly
if (require.main === module) {
  console.log("Starting email test...");
  console.log("Current working directory:", process.cwd());
  console.log("Checking credentials file:");
  console.log("Credentials path:", credentialsPath);
  console.log("Tokens path:", tokenPath);

  async function testEmail() {
    try {
      console.log("\nTesting Gmail API connection...");
      await testGmailApi();
      console.log("Gmail API connection successful!");

      console.log("\nTesting email sending...");
      const response = await sendEmail(
        "derekgallardo01@gmail.com",
        "Test Email from TCG Market",
        `<h1>Test Email</h1>
        <p>This is a test email sent from the TCG Market application using Gmail API.</p>
        <p>If you're receiving this, the email functionality is working correctly!</p>
        <p>Timestamp: ${new Date().toLocaleString("en-US", { timeZone: "America/New_York" })}</p>`
      );
      console.log("\nEmail sent successfully!", response);
    } catch (error) {
      console.error("\nError during test:", {
        message: (error as AuthError).message,
        stack: (error as AuthError).stack,
        response: (error as AuthError).response?.data,
        code: (error as AuthError).code,
        status: (error as AuthError).response?.status,
      });
      process.exit(1);
    }
  }

  testEmail();
}